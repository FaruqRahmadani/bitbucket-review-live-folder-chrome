{
  "manifest_version": 3,
  "name": "Bitbucket Review Live Folder",
  "version": "1.0",
  "permissions": [
    "tabs",
    "tabGroups",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://bitbucket.org/*",
    "https://api.bitbucket.org/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}